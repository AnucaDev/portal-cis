# ─────────────────────────────────────────────
#  .gitignore – Proyecto CIS (Portal Web)
# ─────────────────────────────────────────────

# ── Node.js ──────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ── Variables de entorno ─────────────────────
.env
.env.local
.env.*.local

# ── Credenciales y accesos sensibles ─────────
acceso_admin.txt
generar_hash.txt
private/

# ── Editores e IDEs ──────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user

# ── Sistema operativo ────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ── Logs y temporales ────────────────────────
*.log
*.tmp
*.bak
dist/
build/
